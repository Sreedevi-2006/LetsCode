class Solution:
    def isPalindrome(self, x: int) -> bool:
     num = x
     if (x<0 or x%10 == 0 and x!=0):
         return False
     else:
         revert = 0
         while x!=0:
             revert = (revert*10) + x%10
             x = x//10
     if num == revert:
         return True
     else:
         return False 
