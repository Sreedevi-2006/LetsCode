class Solution:
    def countEven(self, num: int) -> int:
        sum = 0
        n =0
        for i in range(1,num+1):
            sum = 0
            x = i
            if x<10:
                sum += x
            else:
                while x!=0:
                    d = x%10
                    sum+=d
                    x = x//10
                    
                 
            if sum%2 == 0:
                n += 1
        return n
                
        
